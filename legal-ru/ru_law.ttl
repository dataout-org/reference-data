@prefix law: <https://dataout.org/rdf/reference/ru_law#> .
@prefix dataout: <https://dataout.org/ontology#> .
@prefix region: <https://dataout.org/rdf/reference/ru_regions#> .
@prefix schema: <https://schema.org/> .

law:CAORF a schema:Legislation ;
    schema:legislationType dataout:administrativeCode ;
    schema:name "Code of Administrative Offences of the Russian Federation"@en, "Кодекс Российской Федерации об административных правонарушениях"@ru ;
    schema:jurisdiction region:RU ;
    schema:hasPart law:article_6_21 , law:article_6_21_2 .

law:article_6_21 a schema:Legislation ;
    schema:isPartOf law:CAORF ;
    schema:name "Article 6.21"@en .

